# Banco de dados
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require
# Máximo de conexões simultâneas no pool compartilhado (padrão 10).
PGPOOL_MAX=10
# Pool reservado só para login/sessão (padrão 3) — evita timeout no PGStore.
PGSESSION_POOL_MAX=3
# intranet-api (chat): SERVICE_PROFILE=chat | Intranet principal: full ou omitir
SERVICE_PROFILE=full

# Omie
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_WEBHOOK_TOKEN=

# GitHub (se usado por integracoes internas)
GITHUB_TOKEN=
GITHUB_BRANCH=main
GITHUB_OWNER=qualidafromtherm2
GITHUB_REPO=Intranet
GITHUB_PATH=imagens

# Armazenamento de arquivos — Cloudflare R2 (obrigatório)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=intranet-fromtherm
R2_PUBLIC_BASE_URL=https://pub-SEU_ID.r2.dev
STORAGE_BUCKET=produtos

# OpenAI (Assistente SGF)
OPENAI_API_KEY=

# E-mail SMTP (devolução AT e futuros alertas) — Brevo gratuito recomendado
# Conta: https://www.brevo.com/ → SMTP & API → SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remetente de fallback (obrigatório no Brevo: domínio/e-mail verificado).
# O botão Devolução tenta usar o e-mail do usuário logado (auth_user.email);
# se o Brevo rejeitar e-mails não verificados, use um fixo verificado aqui.
SMTP_FROM="Fromtherm Intranet <noreply@seudominio.com>"
# Fallback opcional de destinatários (só se ninguém estiver ativo em AT → Destinatários de devolução)
AT_DEVOLUCAO_EMAILS=

# Opcional: forcar uso de DB em ambiente local
FORCE_DB=0

# Google Sheets — registrar OP na aba PRODUÇÃO 2 - F/ ESCOPO (Apps Script)
GOOGLE_SHEETS_OP_WEBHOOK_URL=
