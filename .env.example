# Banco de dados
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require
# Máximo de conexões simultâneas no pool compartilhado (padrão 5). Reduza se ver "Connection terminated unexpectedly" ao iniciar.
PGPOOL_MAX=5

# Omie
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_WEBHOOK_TOKEN=

# GitHub (se usado por integracoes internas)
GITHUB_TOKEN=
GITHUB_BRANCH=main
GITHUB_OWNER=qualidafromtherm2
GITHUB_REPO=Intranet
GITHUB_PATH=imagens

# Armazenamento de arquivos — Cloudflare R2 (obrigatório)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=intranet-fromtherm
R2_PUBLIC_BASE_URL=https://pub-SEU_ID.r2.dev
STORAGE_BUCKET=produtos

# OpenAI (Assistente SGF)
OPENAI_API_KEY=

# Opcional: forcar uso de DB em ambiente local
FORCE_DB=0
