# =====================
# Intranet - .env.example
# =====================
# Copie para .env e preencha com seus valores reais:
# cp .env.example .env

# =====================
# Basico para subir local
# =====================
NODE_ENV=development
PORT=5001
SESSION_SECRET=troque-isto-em-desenvolvimento
API_URL=http://localhost:5001

# =====================
# Banco de dados (obrigatorio para rotas que usam Postgres)
# Preferencia: use apenas DATABASE_URL
# =====================
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require

# Alternativas ao DATABASE_URL (opcional)
POSTGRES_URL=
POSTGRES_INTERNAL_URL=
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require
PGPOOL_MAX=5

# Compatibilidade com scripts/migracoes (opcional)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=
FORCE_DB=0

# =====================
# Omie (necessario para sincronizacoes e rotas Omie)
# =====================
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_WEBHOOK_TOKEN=

# Alias usados por alguns scripts legados (opcional)
OMIE_KEY=
OMIE_SECRET=
APP_KEY=
APP_SECRET=

# Parametros opcionais de integracao Omie
OMIE_COD_PARCELA_PADRAO=
OMIE_FORNECEDOR_PADRAO_ID=
OMIE_ESTRUTURA_URL=
OMIE_WEBHOOK_AUTOSYNC_ENABLED=0
OMIE_WEBHOOK_AUTOSYNC_RUN_ON_STARTUP=0
OMIE_WEBHOOK_AUTOSYNC_INTERVAL_MS=180000
OMIE_WEBHOOK_AUTOSYNC_PRODUTOS_PAGES_PER_RUN=2

# =====================
# Supabase (opcional para subir servidor)
# Necessario apenas para uploads (fotos/anexos/sac)
# =====================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
SUPABASE_BUCKET=produtos
SUPABASE_BUCKET_SAC=sac-envios

# =====================
# Google OAuth (opcional)
# Necessario para login Google / Google Calendar
# =====================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Integracao Google Sheets (opcional)
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_PLANILHA_URL=
GOOGLE_SHEETS_SYNC_MODE=manual
GOOGLE_SHEETS_AUTOSYNC_ENABLED=0
GOOGLE_SHEETS_AUTOSYNC_INTERVAL_MS=300000

# =====================
# Integracoes de rastreio/logistica (opcional)
# =====================
TRACK_USER=
TRACK_TOKEN=
TRACK_BASE_URL=
TRACKINGMORE_API_KEY=
TRACKINGMORE_TOKEN=
TRACKINGMORE_URL=
WONCA_API_KEY=
WONCA_TOKEN=
WONCA_TRACK_URL=

# =====================
# Outros opcionais do projeto
# =====================
INTERNAL_TOKEN=changeme
CHAT_DEBUG=0
PRINT_WORKER_CONFIG=./print_worker_config.json
PRINTER=
MY_ZPL_SECRET=

# Locais padrao (UI)
ALMOX_LOCAL_PADRAO=10408201806
PRODUCAO_LOCAL_PADRAO=10564345392
COD_LOCAL_ESTOQUE=

# Tabela custom para PCP (opcional)
PCP_ESTRUTURA_TABLE=

# GitHub (apenas se usar rotinas internas que dependem da API)
GITHUB_TOKEN=
GITHUB_BRANCH=main
GITHUB_OWNER=qualidafromtherm2
GITHUB_REPO=Intranet
GITHUB_PATH=imagens